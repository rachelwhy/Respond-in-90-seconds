# 复制为项目根目录 `.env` 后填写密钥即可联调。
# 算法侧长文本切片、LangExtract 并行度、Docling 表格模式等均为内置策略，无需前端逐项配置。

A23_MODEL_TYPE=deepseek
A23_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
A23_DEEPSEEK_API_KEY=sk-your-api-key-here
A23_DEEPSEEK_MODEL=deepseek-chat

# 可选：Ollama / OpenAI 兼容 / 通义千问（按需改 MODEL_TYPE 与对应 KEY）
# A23_MODEL_TYPE=ollama
# A23_OLLAMA_MODEL=qwen2.5:7b
# A23_MODEL_TYPE=openai
# A23_OPENAI_BASE_URL=http://localhost:1234/v1
# A23_OPENAI_API_KEY=sk-dummy-key
# A23_OPENAI_MODEL=qwen2.5-7b
# A23_MODEL_TYPE=qwen
# A23_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# A23_QWEN_API_KEY=

# 算法端内置异步任务 /api/tasks/*（默认 false；业务后端自有队列时保持 false，worker 调 POST /api/extract/direct）
A23_ENABLE_TASKS=false
# 同步抽取是否落盘到 storage/uploads/<id>/（见 HTTP_API_USAGE.md）
A23_PERSIST_UPLOADS=true

# 浏览器网页端 / SPA 跨域：默认含常见 localhost 端口 + 正则匹配 localhost/127.0.0.1/::1 及私网段任意端口（便于不同端口、局域网调试）；同源网关部署不受影响。
# 生产公网前端追加 Origin： A23_CORS_ORIGINS=https://your-app.example.com
# 设为 * 可允许任意源（Cookie 凭证关闭）： A23_CORS_ORIGINS=*
# 仅白名单、关闭正则： A23_CORS_ORIGIN_REGEX=
# A23_CORS_ALLOW_CREDENTIALS=true

A23_WRITE_RESULT_REPORT_BUNDLE=false
A23_DATE_FALLBACK_FIELD_NAME=date
A23_TARGET_LIMIT_SECONDS=90
A23_EXTRACTION_TIMEOUT=240
A23_FUZZY_THRESHOLD=75
A23_NORMALIZATION_CONFIG=src/knowledge/field_normalization_rules.json
A23_ENABLE_OCR=false

# 可选：LiteLLM（pip install litellm）
# A23_USE_LITELLM=false
# A23_LITELLM_MODEL=

# 文档问答 POST /api/qna/ask：依赖见 requirements.txt；装完后可运行 python scripts/verify_qna_deps.py
# 生成答案用的聊天模型：默认 deepseek，与抽取 A23_MODEL_TYPE 独立；可按需改为 ollama 等
# A23_QNA_MODEL_TYPE=deepseek
# 句向量模型：默认离线——若仓库下已有 models/qna_embedding（见下方下载脚本）则自动使用，不会访问 huggingface.co。
# 预下载（仅需一次，可设镜像）：
#   HF_ENDPOINT=https://hf-mirror.com
#   python scripts/download_qna_embedding_model.py
# 可选显式指定目录或 Hub 模型名（设 Hub 名时才联网解析模型）：
# A23_QNA_SENTENCE_TRANSFORMER=models/qna_embedding
# A23_QNA_SENTENCE_TRANSFORMER=paraphrase-multilingual-MiniLM-L12-v2
# A23_QNA_HYBRID_ALPHA=0.65
# 是否在算法侧持久化 storage/sessions（false 时用临时目录；多轮由业务库存 history，请求传 history_json + 每次 files）
# A23_QNA_PERSIST_SESSION=true
# 问答默认 LangChain + Chroma；false 时仅用 BM25+向量混合检索（见 HTTP_API_USAGE）
# A23_QNA_USE_LANGCHAIN=true
