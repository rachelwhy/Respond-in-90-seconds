# --- Python 缓存 ---
__pycache__/
*.py[cod]
*$py.class

# --- 环境与私密信息 ---
# 忽略存储 API Key 的环境文件
.env
local_settings.py

# --- 算法产生的临时文件 ---
# 你的 server.py 会产生 cache_ 开头的文件
cache_*
temp_*
output.json

# --- 办公软件产生的临时文件 (解析时产生的) ---
~$*
.DS_Store

# --- 虚拟环境 ---
venv/
env/
.venv/

# --- IDE 配置 ---
.vscode/
.idea/

# --- 测试数据 (可选) ---
# 如果你不希望别人看到你的测试 PDF 或 Excel，取消下面两行的注释
# *.pdf
# *.xlsx